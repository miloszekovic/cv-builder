# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# generated CV / PDF demo output (see npm run demo:pdf)
/output/

# playwright (reports if you add e2e tests later)
/test-results/
/playwright-report/
/blob-report/

# turbopack / tooling cache
.turbo
.eslintcache

# vercel
.vercel

# env (keep .env.example tracked)
.env
.env.*
!.env.example
.envrc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# typescript
*.tsbuildinfo
# generated by Next.js; references .next/ — regenerate locally with `next dev` / `next build`
next-env.d.ts

# misc
.DS_Store
*.pem
Thumbs.db

# editors
.idea/
