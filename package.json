{
  "name": "cv-gen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PLAYWRIGHT_BROWSERS_PATH=0 next dev",
    "build:print-css": "tailwindcss -i ./styles/print-entry.css -o ./public/cv-print.css --minify",
    "build": "npm run build:print-css && PLAYWRIGHT_BROWSERS_PATH=0 next build",
    "start": "PLAYWRIGHT_BROWSERS_PATH=0 next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "demo:pdf": "npm run build:print-css && PLAYWRIGHT_BROWSERS_PATH=0 tsx scripts/generate-demo-pdf.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "lucide-react": "^0.469.0",
    "next": "16.2.4",
    "openai": "^6.36.0",
    "playwright": "^1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
